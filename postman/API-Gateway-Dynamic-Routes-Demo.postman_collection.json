          },
          "response": []
        },
        {
          "name": "4. Login To Issue Access And Refresh Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('jwtAccessToken', body.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"jwt-gateway\",\n  \"username\": \"{{registeredUsername}}\",\n  \"password\": \"{{registeredPassword}}\"\n}"
            },
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/login",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Issues signed access and refresh tokens from consumer-service for a consumer that belongs to the JWT gateway."
          },
          "response": []
        },
        {
          "name": "5. Validate Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"jwt-gateway\",\n  \"token\": \"{{jwtAccessToken}}\"\n}"
            },
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/token/validate",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "token",
                "validate"
              ]
            },
            "description": "Validates an issued JWT access token and confirms it belongs to the JWT gateway before using it on the protected route."
          },
          "response": []
        },
        {
          "name": "6. Call JWT Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/jwt/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "jwt",
                "products"
              ]
            },
            "description": "Calls the JWT protected route with the bearer token issued by consumer-service."
          },
          "response": []
        }
      ]
    },
    {
      "name": "OAuth2",
      "item": [
        {
          "name": "1. Create OAuth2 Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"oauth2-gateway\",\n  \"gatewayName\": \"OAuth2 Gateway\",\n  \"description\": \"Gateway workspace for IAM-backed bearer token enforcement.\",\n  \"authType\": \"OAUTH2\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Optional example: creates a gateway whose default policy is OAUTH2."
          },
          "response": []
        },
        {
          "name": "2. Register OAuth2 Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"oauth2-gateway\",\n  \"serviceId\": \"product-service-oauth2\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"oauth2\"]\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into the OAUTH2 gateway. The service automatically uses the gateway's OAUTH2 policy."
          },
          "response": []
        },
        {
          "name": "3. Create OAuth2 Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"oauth2-gateway\",\n  \"serviceId\": \"product-service-oauth2\",\n  \"id\": \"product-route-oauth2\",\n  \"path\": \"/oauth2/products/**\",\n  \"uri\": \"lb://product-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route inside the OAUTH2 gateway. The route automatically uses the gateway's OAUTH2 policy."
          },
          "response": []
        },
        {
          "name": "4. Request OAuth2 Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('oauth2AccessToken', body.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{oauth2ClientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{oauth2ClientSecret}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "openid profile email",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/token",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "token"
              ]
            },
            "description": "Requests an access token from iam-server using the seeded OAuth2 client itp-standard / qwerqwer."
          },
          "response": []
        },
        {
          "name": "5. Call OAuth2 Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{oauth2AccessToken}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/oauth2/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "products"
              ]
            },
            "description": "Calls an OAuth2 protected route through standard-gateway using an access token issued by iam-server."
          },
          "response": []
        }
      ]
    }
  ]
}
