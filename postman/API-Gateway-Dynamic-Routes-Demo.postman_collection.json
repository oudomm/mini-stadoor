{
  "info": {
    "_postman_id": "f9a8ab4b-4c4d-4f74-9c36-6ef0a2b7f0d1",
    "name": "API Gateway Dynamic Routes Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Simple demo collection for dynamic service registration and route security using standard-gateway, gateway-service, consumer-service, and product-service."
  },
  "variable": [
    {
      "key": "standardGatewayBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "gatewayServiceBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "eurekaBaseUrl",
      "value": "http://localhost:8761"
    }
  ],
  "item": [
    {
      "name": "Non Auth",
      "item": [
        {
          "name": "1. Register Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"product-service-manual-1\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"proof\"]\n}"
            },
            "url": {
              "raw": "{{gatewayServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into Eureka by platform API."
          },
          "response": []
        },
        {
          "name": "2. Create Non Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"product-route-open\",\n  \"path\": \"/open/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"NONE\"\n}"
            },
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/internal/routes",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates an open route with no auth."
          },
          "response": []
        },
        {
          "name": "3. Call Open Route",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/open/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "open",
                "products"
              ]
            },
            "description": "Calls product-service through standard-gateway without auth."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Basic Auth",
      "item": [
        {
          "name": "1. Create Basic Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"product-route-basic\",\n  \"path\": \"/basic/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"BASIC\"\n}"
            },
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/internal/routes",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a route protected by Basic Auth."
          },
          "response": []
        },
        {
          "name": "2. Call Basic Auth Route",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "enduser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "enduser123",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/basic/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "basic",
                "products"
              ]
            },
            "description": "Calls a Basic Auth protected route through standard-gateway."
          },
          "response": []
        }
      ]
    },
    {
      "name": "API Key",
      "item": [
        {
          "name": "1. Create API Key Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"product-route-api-key\",\n  \"path\": \"/api-key/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"API_KEY\"\n}"
            },
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/internal/routes",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a route protected by API key validation."
          },
          "response": []
        },
        {
          "name": "2. Call API Key Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "stadoor-demo-key"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api-key/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api-key",
                "products"
              ]
            },
            "description": "Calls an API key protected route through standard-gateway."
          },
          "response": []
        }
      ]
    }
  ]
}
