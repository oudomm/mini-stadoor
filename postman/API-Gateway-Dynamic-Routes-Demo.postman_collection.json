{
  "info": {
    "_postman_id": "f9a8ab4b-4c4d-4f74-9c36-6ef0a2b7f0d1",
    "name": "API Gateway Dynamic Routes Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Simple demo collection for gateway-scoped service registration and route security using standard-gateway, gateway-management-service, consumer-service, and product-service."
  },
  "variable": [
    {
      "key": "standardGatewayBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "gatewayManagementServiceBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "eurekaBaseUrl",
      "value": "http://localhost:8761"
    },
    {
      "key": "consumerServiceBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "iamServerBaseUrl",
      "value": "http://localhost:9090"
    },
    {
      "key": "platformOAuthClientId",
      "value": "mini-stadoor-postman"
    },
    {
      "key": "platformOAuthClientSecret",
      "value": "mini-stadoor-postman-secret"
    },
    {
      "key": "platformRedirectUri",
      "value": "https://oauth.pstmn.io/v1/browser-callback"
    },
    {
      "key": "platformAuthorizationCode",
      "value": ""
    },
    {
      "key": "platformAccessToken",
      "value": ""
    },
    {
      "key": "registeredUsername",
      "value": "alice-demo"
    },
    {
      "key": "registeredPassword",
      "value": "alice12345"
    },
    {
      "key": "registeredApiKey",
      "value": ""
    },
    {
      "key": "jwtAccessToken",
      "value": ""
    },
    {
      "key": "oauth2ClientId",
      "value": "itp-standard"
    },
    {
      "key": "oauth2ClientSecret",
      "value": "qwerqwer"
    },
    {
      "key": "oauth2AccessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Gateway Setup + Non Auth",
      "item": [
        {
          "name": "1. Create Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"gatewayName\": \"E-Commerce Gateway\",\n  \"description\": \"Gateway workspace for catalog, checkout, and customer APIs.\",\n  \"authType\": \"NONE\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Creates the top-level gateway workspace for the authenticated developer with a gateway default auth policy. This sample uses NONE so later requests can demonstrate route-level overrides."
          },
          "response": []
        },
        {
          "name": "2. Register Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"proof\"],\n  \"authType\": null\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into the authenticated developer's gateway workspace. This sample leaves authType null so each route can choose its own auth policy. Set authType to BASIC, API_KEY, JWT, or NONE if you want every route in this service to inherit one policy."
          },
          "response": []
        },
        {
          "name": "3. Create Non Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-open\",\n  \"path\": \"/open/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": null\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates an open route inside the authenticated developer's e-commerce gateway. Because the service authType is null and this route authType is null, the route inherits the gateway default NONE policy."
          },
          "response": []
        },
        {
          "name": "4. Call Open Route",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/open/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "open",
                "products"
              ]
            },
            "description": "Calls product-service through standard-gateway without auth because the route resolves to the gateway default NONE policy."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consumer User",
      "item": [
        {
          "name": "1. Register Consumer User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('registeredUsername', body.username);",
                  "pm.collectionVariables.set('registeredApiKey', body.apiKey);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registeredUsername}}\",\n  \"password\": \"{{registeredPassword}}\"\n}"
            },
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/users/register",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "Registers a consumer-service user. The returned API key is stored in the collection variable registeredApiKey."
          },
          "response": []
        }
      ]
    },
    {
      "name": "IAM Server",
      "item": [
        {
          "name": "1. OIDC Discovery",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/.well-known/openid-configuration",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                ".well-known",
                "openid-configuration"
              ]
            },
            "description": "Checks that the copied iam-server is running as an OpenID Connect authorization server."
          },
          "response": []
        },
        {
          "name": "2. Public Welcome",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/public/welcome",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "public",
                "welcome"
              ]
            },
            "description": "Calls a public iam-server endpoint without authentication."
          },
          "response": []
        },
        {
          "name": "3. Login Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/login",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Opens the form login page for iam-server. Demo credentials from the copied service are oudom / qwer."
          },
          "response": []
        },
        {
          "name": "4. Protected Users Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/api/v1/users",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Protected endpoint in iam-server. In Postman this will redirect to login unless you authenticate with the session flow manually."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Platform IAM",
      "item": [
        {
          "name": "1. Open Portal Authorize URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/authorize?response_type=code&client_id={{platformOAuthClientId}}&redirect_uri={{platformRedirectUri}}&scope=openid%20profile%20email&state=postman-state&nonce=postman-nonce",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "authorize"
              ],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{platformOAuthClientId}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{platformRedirectUri}}"
                },
                {
                  "key": "scope",
                  "value": "openid profile email"
                },
                {
                  "key": "state",
                  "value": "postman-state"
                },
                {
                  "key": "nonce",
                  "value": "postman-nonce"
                }
              ]
            },
            "description": "Open this request in a browser, sign in with iam-server, then copy the code query parameter from the redirect URL into the collection variable platformAuthorizationCode."
          },
          "response": []
        },
        {
          "name": "2. Exchange Portal Authorization Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('platformAccessToken', body.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{platformOAuthClientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{platformOAuthClientSecret}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text"
                },
                {
                  "key": "code",
                  "value": "{{platformAuthorizationCode}}",
                  "type": "text"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{platformRedirectUri}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/token",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "token"
              ]
            },
            "description": "Exchanges the copied authorization code for a developer access token and stores it in platformAccessToken."
          },
          "response": []
        },
        {
          "name": "3. List My Gateways",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Lists only the gateways owned by the authenticated developer."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Basic Auth",
      "item": [
        {
          "name": "1. Create Basic Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-basic\",\n  \"path\": \"/basic/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"BASIC\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route protected by Basic Auth. This works because the service was registered with authType null, so this route can override the gateway default with BASIC."
          },
          "response": []
        },
        {
          "name": "2. Call Basic Auth Route",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{registeredUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{registeredPassword}}",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/basic/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "basic",
                "products"
              ]
            },
            "description": "Calls a Basic Auth protected route through standard-gateway using the consumer credentials created earlier."
          },
          "response": []
        }
      ]
    },
    {
      "name": "API Key",
      "item": [
        {
          "name": "1. Create API Key Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-api-key\",\n  \"path\": \"/api-key/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"API_KEY\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route protected by API key validation. This route sets API_KEY directly because the service authType is still null."
          },
          "response": []
        },
        {
          "name": "2. Call API Key Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{registeredApiKey}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api-key/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api-key",
                "products"
              ]
            },
            "description": "Calls an API key protected route through standard-gateway using the API key returned by consumer registration."
          },
          "response": []
        }
      ]
    },
    {
      "name": "JWT",
      "item": [
        {
          "name": "1. Create JWT Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-jwt\",\n  \"path\": \"/jwt/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"JWT\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route protected by JWT bearer token validation. This route sets JWT directly because the service authType is still null."
          },
          "response": []
        },
        {
          "name": "2. Login To Issue Access And Refresh Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('jwtAccessToken', body.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registeredUsername}}\",\n  \"password\": \"{{registeredPassword}}\"\n}"
            },
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/login",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Issues signed access and refresh tokens from consumer-service for the registered consumer user."
          },
          "response": []
        },
        {
          "name": "3. Validate Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/token/validate",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "token",
                "validate"
              ]
            },
            "description": "Validates an issued JWT access token."
          },
          "response": []
        },
        {
          "name": "4. Call JWT Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/jwt/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "jwt",
                "products"
              ]
            },
            "description": "Calls a JWT protected route through standard-gateway with the bearer token issued by consumer-service."
          },
          "response": []
        }
      ]
    },
    {
      "name": "OAuth2",
      "item": [
        {
          "name": "1. Create OAuth2 Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-oauth2\",\n  \"path\": \"/oauth2/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"OAUTH2\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Optional IAM-backed example: creates a route protected by OAuth2 bearer token validation through iam-server. Like the other route-level examples, this works because the service authType is null."
          },
          "response": []
        },
        {
          "name": "2. Request OAuth2 Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('oauth2AccessToken', body.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{oauth2ClientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{oauth2ClientSecret}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "openid profile email",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/token",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "token"
              ]
            },
            "description": "Requests an access token from iam-server using the seeded OAuth2 client itp-standard / qwerqwer."
          },
          "response": []
        },
        {
          "name": "3. Call OAuth2 Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{oauth2AccessToken}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/oauth2/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "products"
              ]
            },
            "description": "Calls an OAuth2 protected route through standard-gateway using an access token issued by iam-server."
          },
          "response": []
        }
      ]
    }
  ]
}
