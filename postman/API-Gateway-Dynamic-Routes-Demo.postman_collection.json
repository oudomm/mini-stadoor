{
  "info": {
    "_postman_id": "f9a8ab4b-4c4d-4f74-9c36-6ef0a2b7f0d1",
    "name": "API Gateway Dynamic Routes Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Demo collection for runtime service registration and dynamic routing using standard-gateway, gateway-service, and product-service."
  },
  "variable": [
    {
      "key": "standardGatewayBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "gatewayServiceBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "productServiceBaseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "eurekaBaseUrl",
      "value": "http://localhost:8761"
    },
    {
      "key": "inventoryServiceBaseUrl",
      "value": "http://localhost:8090"
    },
    {
      "key": "customerServiceBaseUrl",
      "value": "http://localhost:8091"
    }
  ],
  "item": [
    {
      "name": "Developer To End User Flow",
      "item": [
        {
          "name": "1. Register Developer Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"product-service-manual-1\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"proof\"]\n}"
            },
            "url": {
              "raw": "{{gatewayServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Platform-managed runtime registration of a developer service into Eureka."
          },
          "response": []
        },
        {
          "name": "2. Create Dynamic Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"product-route\",\n  \"path\": \"/api/products/**\",\n  \"uri\": \"lb://product-service\",\n  \"authType\": \"BASIC\"\n}"
            },
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/internal/routes",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a runtime gateway route that resolves the registered product service through Eureka."
          },
          "response": []
        },
        {
          "name": "3. End User Calls Standard Gateway",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "enduser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "enduser123",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "End users call standard-gateway directly. standard-gateway delegates Basic Auth validation to consumer-service, then resolves the registered product service dynamically."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Discovery Check",
      "item": [
        {
          "name": "1. Query Eureka App Instances",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{eurekaBaseUrl}}/eureka/apps/PRODUCT-SERVICE",
              "host": [
                "{{eurekaBaseUrl}}"
              ],
              "path": [
                "eureka",
                "apps",
                "PRODUCT-SERVICE"
              ]
            },
            "description": "Shows Eureka has the registered product-service instance."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Express Inventory Flow",
      "item": [
        {
          "name": "1. Register Inventory Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"inventory-service-manual-1\",\n  \"serviceName\": \"inventory-service\",\n  \"address\": \"localhost\",\n  \"port\": 8090,\n  \"tags\": [\"express\", \"manual-registration\"]\n}"
            },
            "url": {
              "raw": "{{gatewayServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers the Express-based inventory service into Eureka at runtime."
