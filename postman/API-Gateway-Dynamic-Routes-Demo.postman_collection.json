{
  "info": {
    "_postman_id": "f9a8ab4b-4c4d-4f74-9c36-6ef0a2b7f0d1",
    "name": "API Gateway Dynamic Routes Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Demo collection for developer IAM, dynamic gateway registration, consumer credential issuance, and protected route calls across NONE, BASIC, API_KEY, JWT, and optional OAUTH2 flows."
  },
  "variable": [
    {
      "key": "standardGatewayBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "gatewayManagementServiceBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "eurekaBaseUrl",
      "value": "http://localhost:8761"
    },
    {
      "key": "consumerServiceBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "iamServerBaseUrl",
      "value": "http://localhost:9090"
    },
    {
      "key": "platformOAuthClientId",
      "value": "mini-stadoor-postman"
    },
    {
      "key": "platformOAuthClientSecret",
      "value": "mini-stadoor-postman-secret"
    },
    {
      "key": "platformRedirectUri",
      "value": "https://oauth.pstmn.io/v1/browser-callback"
    },
    {
      "key": "platformAuthorizationCode",
      "value": ""
    },
    {
