{
  "info": {
    "_postman_id": "f9a8ab4b-4c4d-4f74-9c36-6ef0a2b7f0d1",
    "name": "API Gateway Dynamic Routes Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Demo collection for runtime service registration and dynamic routing using gateway-service, route-management-service, and product-service."
  },
  "variable": [
    {
      "key": "gatewayBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "routeManagementBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "productServiceBaseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "eurekaBaseUrl",
      "value": "http://localhost:8761"
    },
    {
      "key": "inventoryServiceBaseUrl",
      "value": "http://localhost:8090"
    }
  ],
  "item": [
    {
      "name": "Developer To End User Flow",
      "item": [
        {
          "name": "1. Register Developer Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"product-service-manual-1\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"proof\"]\n}"
            },
            "url": {
              "raw": "{{routeManagementBaseUrl}}/services/register",
              "host": [
                "{{routeManagementBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Platform-managed runtime registration of a developer service into Eureka."
          },
          "response": []
        },
        {
          "name": "2. Create Dynamic Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"product-route\",\n  \"path\": \"/api/products/**\",\n  \"uri\": \"lb://product-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/internal/routes",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a runtime gateway route that resolves the registered product service through Eureka."
          },
          "response": []
        },
        {
          "name": "3. End User Calls Gateway",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/products",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "End users access only the gateway URL. The gateway resolves the registered product service dynamically and forwards the request."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Discovery Check",
      "item": [
        {
          "name": "1. Query Eureka App Instances",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{eurekaBaseUrl}}/eureka/apps/PRODUCT-SERVICE",
              "host": [
                "{{eurekaBaseUrl}}"
              ],
              "path": [
                "eureka",
                "apps",
                "PRODUCT-SERVICE"
              ]
            },
            "description": "Shows Eureka has the registered product-service instance."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Express Inventory Flow",
      "item": [
        {
          "name": "1. Register Inventory Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"inventory-service-manual-1\",\n  \"serviceName\": \"inventory-service\",\n  \"address\": \"localhost\",\n  \"port\": 8090,\n  \"tags\": [\"express\", \"manual-registration\"]\n}"
            },
            "url": {
              "raw": "{{routeManagementBaseUrl}}/services/register",
              "host": [
                "{{routeManagementBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers the Express-based inventory service into Eureka at runtime."
          },
          "response": []
        },
        {
          "name": "2. Create Inventory Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"inventory-route\",\n  \"path\": \"/api/inventory/**\",\n  \"uri\": \"lb://inventory-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayBaseUrl}}/internal/routes",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a runtime route for the Express inventory service."
          },
          "response": []
        },
        {
          "name": "3. End User - List Inventory",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/inventory/items",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items"
              ]
            },
            "description": "Calls the inventory list endpoint through the gateway."
          },
          "response": []
        },
        {
          "name": "4. End User - Inventory By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/inventory/items/i-100",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items",
                "i-100"
              ]
            },
            "description": "Calls a specific inventory item through the gateway."
          },
          "response": []
        },
        {
          "name": "5. End User - Low Stock",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}/api/inventory/items/low-stock",
              "host": [
                "{{gatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items",
                "low-stock"
              ]
            },
            "description": "Calls the low-stock endpoint through the gateway."
          },
          "response": []
        },
        {
          "name": "6. Direct Inventory Service (Optional)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{inventoryServiceBaseUrl}}/inventory/items",
              "host": [
                "{{inventoryServiceBaseUrl}}"
              ],
              "path": [
                "inventory",
                "items"
              ]
            },
            "description": "Direct check that the Express service itself is running before routing through the gateway."
          },
          "response": []
        }
      ]
    }
  ]
}
