      "value": "itp-standard"
    },
    {
      "key": "oauth2ClientSecret",
      "value": "qwerqwer"
    },
    {
      "key": "oauth2AccessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Gateway Setup + Non Auth",
      "item": [
        {
          "name": "1. Create Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"gatewayName\": \"E-Commerce Gateway\",\n  \"description\": \"Gateway workspace for catalog, checkout, and customer APIs.\",\n  \"authType\": \"NONE\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Creates an open gateway workspace with the default policy NONE. Use this folder only for the public no-auth example."
          },
          "response": []
        },
        {
          "name": "2. Register Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"proof\"]\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into the open gateway. The service automatically uses the gateway's NONE policy."
          },
          "response": []
        },
        {
          "name": "3. Create Non Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"ecommerce-gateway\",\n  \"serviceId\": \"product-service-manual-1\",\n  \"id\": \"product-route-open\",\n  \"path\": \"/open/products/**\",\n  \"uri\": \"lb://product-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates an open route inside the NONE gateway. The route automatically uses the gateway's NONE policy."
          },
          "response": []
        },
        {
          "name": "4. Call Open Route",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/open/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "open",
                "products"
              ]
            },
            "description": "Calls product-service through standard-gateway without auth because the route resolves to the gateway default NONE policy."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consumer User",
      "item": [
        {
          "name": "1. Register Consumer User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('registeredUsername', body.username);",
                  "pm.collectionVariables.set('registeredApiKey', body.apiKey);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"{{consumerGatewayId}}\",\n  \"consumerName\": \"Partner Client {{consumerGatewayId}}\",\n  \"username\": \"{{registeredUsername}}\",\n  \"password\": \"{{registeredPassword}}\"\n}"
            },
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/consumers",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "consumers"
              ]
            },
            "description": "Registers a gateway-scoped consumer identity in consumer-service. Set consumerGatewayId to the gateway you want to test, then reuse the returned API key or username/password only inside that gateway."
          },
          "response": []
        },
        {
          "name": "2. List Consumers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{consumerServiceBaseUrl}}/api/consumers?gatewayId={{consumerGatewayId}}",
              "host": [
                "{{consumerServiceBaseUrl}}"
              ],
              "path": [
                "api",
                "consumers"
              ],
              "query": [
                {
                  "key": "gatewayId",
                  "value": "{{consumerGatewayId}}"
                }
              ]
            },
            "description": "Lists consumer identities for the selected gateway workspace so you can confirm which clients are available for BASIC, API_KEY, and JWT flows."
          },
          "response": []
        }
      ]
    },
    {
      "name": "IAM Server",
      "item": [
        {
          "name": "1. OIDC Discovery",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/.well-known/openid-configuration",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                ".well-known",
                "openid-configuration"
              ]
            },
            "description": "Checks that the copied iam-server is running as an OpenID Connect authorization server."
          },
          "response": []
        },
        {
          "name": "2. Public Welcome",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/public/welcome",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "public",
                "welcome"
              ]
            },
            "description": "Calls a public iam-server endpoint without authentication."
          },
          "response": []
        },
        {
          "name": "3. Login Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/login",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Opens the form login page for iam-server. Demo credentials from the copied service are oudom / qwer."
          },
          "response": []
        },
        {
          "name": "4. Protected Users Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/api/v1/users",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Protected endpoint in iam-server. In Postman this will redirect to login unless you authenticate with the session flow manually."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Platform IAM",
      "item": [
        {
          "name": "1. Open Portal Authorize URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/authorize?response_type=code&client_id={{platformOAuthClientId}}&redirect_uri={{platformRedirectUri}}&scope=openid%20profile%20email&state=postman-state&nonce=postman-nonce",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "authorize"
              ],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{platformOAuthClientId}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{platformRedirectUri}}"
                },
                {
                  "key": "scope",
                  "value": "openid profile email"
                },
                {
                  "key": "state",
                  "value": "postman-state"
                },
                {
                  "key": "nonce",
                  "value": "postman-nonce"
                }
              ]
            },
            "description": "Open this request in a browser, sign in with iam-server, then copy the code query parameter from the redirect URL into the collection variable platformAuthorizationCode."
          },
          "response": []
        },
        {
          "name": "2. Exchange Portal Authorization Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('platformAccessToken', body.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{platformOAuthClientId}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{platformOAuthClientSecret}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text"
                },
                {
                  "key": "code",
                  "value": "{{platformAuthorizationCode}}",
                  "type": "text"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{platformRedirectUri}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{iamServerBaseUrl}}/oauth2/token",
              "host": [
                "{{iamServerBaseUrl}}"
              ],
              "path": [
                "oauth2",
                "token"
              ]
            },
            "description": "Exchanges the copied authorization code for a developer access token and stores it in platformAccessToken."
          },
          "response": []
        },
        {
          "name": "3. List My Gateways",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Lists only the gateways owned by the authenticated developer."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Basic Auth",
      "item": [
        {
          "name": "1. Create Basic Auth Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"basic-gateway\",\n  \"gatewayName\": \"Basic Auth Gateway\",\n  \"description\": \"Gateway workspace for username/password protected product APIs.\",\n  \"authType\": \"BASIC\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Creates a gateway whose default policy is BASIC. Services and routes under this gateway must stay on BASIC or inherit it."
          },
          "response": []
        },
        {
          "name": "2. Register Basic Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"basic-gateway\",\n  \"serviceId\": \"product-service-basic\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"basic-auth\"]\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into the BASIC gateway. The service automatically uses the gateway's BASIC policy."
          },
          "response": []
        },
        {
          "name": "3. Create Basic Auth Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"basic-gateway\",\n  \"serviceId\": \"product-service-basic\",\n  \"id\": \"product-route-basic\",\n  \"path\": \"/basic/products/**\",\n  \"uri\": \"lb://product-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route inside the BASIC gateway. The route automatically uses the gateway's BASIC policy."
          },
          "response": []
        },
        {
          "name": "4. Call Basic Auth Route",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{registeredUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{registeredPassword}}",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/basic/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "basic",
                "products"
              ]
            },
            "description": "Calls the BASIC protected route with the consumer username and password created earlier."
          },
          "response": []
        }
      ]
    },
    {
      "name": "API Key",
      "item": [
        {
          "name": "1. Create API Key Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"api-key-gateway\",\n  \"gatewayName\": \"API Key Gateway\",\n  \"description\": \"Gateway workspace for partner-facing APIs secured with X-API-Key.\",\n  \"authType\": \"API_KEY\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/gateways",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "gateways"
              ]
            },
            "description": "Creates a gateway whose default policy is API_KEY."
          },
          "response": []
        },
        {
          "name": "2. Register API Key Product Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"api-key-gateway\",\n  \"serviceId\": \"product-service-api-key\",\n  \"serviceName\": \"product-service\",\n  \"address\": \"localhost\",\n  \"port\": 8082,\n  \"tags\": [\"manual-registration\", \"api-key\"]\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/services/register",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "services",
                "register"
              ]
            },
            "description": "Registers product-service into the API_KEY gateway. The service automatically uses the gateway's API_KEY policy."
          },
          "response": []
        },
        {
          "name": "3. Create API Key Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{platformAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gatewayId\": \"api-key-gateway\",\n  \"serviceId\": \"product-service-api-key\",\n  \"id\": \"product-route-api-key\",\n  \"path\": \"/api-key/products/**\",\n  \"uri\": \"lb://product-service\"\n}"
            },
            "url": {
              "raw": "{{gatewayManagementServiceBaseUrl}}/routes",
              "host": [
                "{{gatewayManagementServiceBaseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Creates a route inside the API_KEY gateway. The route automatically uses the gateway's API_KEY policy."
          },
          "response": []
        },
        {
          "name": "4. Call API Key Route",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{registeredApiKey}}"
              }
            ],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api-key/products",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api-key",
                "products"
              ]
            },
            "description": "Calls the API_KEY protected route using the API key returned during consumer registration."
          },
          "response": []
        }
      ]
    },
