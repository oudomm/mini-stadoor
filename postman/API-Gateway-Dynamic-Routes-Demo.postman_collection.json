            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"inventory-route\",\n  \"path\": \"/api/inventory/**\",\n  \"uri\": \"lb://inventory-service\",\n  \"authType\": \"BASIC\"\n}"
            },
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/internal/routes",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "internal",
                "routes"
              ]
            },
            "description": "Creates a runtime route for the Express inventory service."
          },
          "response": []
        },
        {
          "name": "3. End User - List Inventory",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "enduser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "enduser123",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api/inventory/items",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items"
              ]
            },
            "description": "Calls the inventory list endpoint through the gateway."
          },
          "response": []
        },
        {
          "name": "4. End User - Inventory By Id",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "enduser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "enduser123",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api/inventory/items/i-100",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items",
                "i-100"
              ]
            },
            "description": "Calls a specific inventory item through the gateway."
          },
          "response": []
        },
        {
          "name": "5. End User - Low Stock",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "enduser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "enduser123",
                  "type": "string"
                }
              ]
            },
            "header": [],
            "url": {
              "raw": "{{standardGatewayBaseUrl}}/api/inventory/items/low-stock",
              "host": [
                "{{standardGatewayBaseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "items",
                "low-stock"
              ]
            },
            "description": "Calls the low-stock endpoint through the gateway."
          },
          "response": []
        },
        {
          "name": "6. Direct Inventory Service (Optional)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{inventoryServiceBaseUrl}}/inventory/items",
              "host": [
                "{{inventoryServiceBaseUrl}}"
              ],
              "path": [
                "inventory",
                "items"
              ]
            },
            "description": "Direct check that the Express service itself is running before routing through the gateway."
          },
          "response": []
        }
      ]
    },
